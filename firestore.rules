rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - career_data: object (required) - The structured career data
    //   - updated_at: string (required, date-time) - Last update timestamp
    //   - uid: string (required) - The user's unique ID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nishantdougall@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUserCareerData(data) {
      return data.keys().hasAll(['career_data', 'updated_at', 'uid']) &&
             data.career_data is map &&
             data.updated_at is string &&
             data.uid is string &&
             data.uid == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own data unless they are an admin
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can only create/update their own data with valid schema
      allow create: if isOwner(userId) && isValidUserCareerData(request.resource.data) && hasOnlyAllowedFields(['career_data', 'updated_at', 'uid']);
      allow update: if isOwner(userId) && isValidUserCareerData(request.resource.data) && hasOnlyAllowedFields(['career_data', 'updated_at', 'uid', 'role']);
      
      // Only admins can delete user data (or the user themselves)
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
